   "source": [
    "from scipy import stats\n",
    "import math\n",
    "data = [2,5,6,6,7,5,9,14,10,2,3,4]\n",
    "\n",
    "sample_std = math.sqrt(stats.tvar(data,ddof=1))\n",
    "print(sample_std)\n",
    "\n",
    "population_variance = math.sqrt(stats.tvar(data,ddof=0))\n",
    "print(population_variance)"
   ]
